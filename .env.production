# Production environment variables (used during `vite build`)
#
# If the frontend is served from the SAME Azure App Service as the backend,
# leave this as /api/v1 (the default).
#
# If the frontend is on a SEPARATE static web app / CDN, set this to the
# backend's full URL, e.g.:
#   VITE_API_BASE=https://tb-bi-backend.azurewebsites.net/api/v1
#
VITE_API_BASE=/api/v1
